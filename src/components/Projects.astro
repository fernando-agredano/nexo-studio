---
const projects = [
  {
    title: "EcoSphere Digital",
    category: "Web / 3D Experiences",
    description: "Una experiencia inmersiva para una organización ambientalista.",
    image: "/images/project-1.svg",
    tags: ["Astro", "GSAP", "Three.js"],
  },
  {
    title: "Nature's Rhythm",
    category: "Video / Storytelling",
    description: "Documental narrativo premiado por su cinematografía.",
    image: "/images/project-2.svg",
    tags: ["After Effects", "Rhythm", "Color Grading"],
  },
  {
    title: "Forest Branding",
    category: "Identity / UI",
    description: "Identidad visual para una firma de arquitectura sustentable.",
    image: "/images/project-3.svg",
    tags: ["Logo Design", "Typography", "Figma"],
  },
];
---

<section id="proyectos" class="section">
  <div class="container">
    <div class="section-header projects-header">
      <h2 class="section-title">Nuestra <span class="text-gradient">Biografía</span> de Proyectos</h2>
      <p class="section-subtitle">Explora nuestra colección de híbridos entre creatividad y tecnología.</p>
    </div>
    
    <div class="projects-grid">
      {projects.map((project) => (
        <div class="project-card glass">
          <div class="project-image-container">
            <img src={project.image} alt={project.title} class="project-image" />
            <div class="project-overlay">
              <div class="tags">
                {project.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <button type="button" class="btn btn-outline small">Ver Caso de Estudio</button>
            </div>
          </div>
          <div class="project-info">
            <span class="project-category">{project.category}</span>
            <h3>{project.title}</h3>
            <p>{project.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.75rem);
    align-items: stretch;
  }
  
  .project-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 1rem;
    min-height: 0;
    transition: var(--transition-smooth);
    border: 1px solid rgba(255,255,255,0.1);
  }

  .project-image-container {
    position: relative;
    width: 100%;
    height: clamp(220px, 28vw, 320px);
    overflow: hidden;
    border-radius: 0.75rem;
    flex-shrink: 0;
  }
  
  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .project-card:hover .project-image {
    transform: scale(1.1);
  }

  .project-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(5, 8, 1, 0.8);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
    padding: 2rem;
  }

  .project-card:hover .project-overlay {
    opacity: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
    justify-content: center;
    max-width: 100%;
  }

  .tag {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.4rem 0.9rem;
    background: rgba(236, 253, 245, 0.12);
    border: 1px solid rgba(16, 185, 129, 0.65);
    border-radius: 100px;
    color: #d1fae5;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.45);
    box-shadow: 0 0 20px rgba(16, 185, 129, 0.15);
  }

  .small {
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
  }

  .project-info {
    padding: 1.5rem 0.5rem;
  }
  
  .project-category {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    font-weight: 700;
    margin-bottom: 0.75rem;
    display: block;
  }
  
  .project-info h3 {
    font-size: clamp(1.15rem, 2.5vw, 1.4rem);
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }
  
  .project-info p {
    color: var(--color-text-muted);
    font-size: clamp(0.9rem, 1.5vw, 1rem);
    line-height: 1.55;
  }

  @media (max-width: 1024px) {
    .projects-grid {
      grid-template-columns: 1fr;
      max-width: 32rem;
      margin: 0 auto;
    }

    .project-image-container {
      height: clamp(240px, 45vw, 300px);
    }
  }

  @media (max-width: 768px) {
    .projects-grid {
      gap: 1.35rem;
      max-width: 100%;
    }

    .project-card {
      padding: 0.75rem;
    }

    .project-image-container {
      height: clamp(200px, 52vw, 260px);
      border-radius: 0.65rem;
    }

    .project-info {
      padding: 1.1rem 0.35rem 0.5rem;
    }

    .project-info h3 {
      font-size: 1.12rem;
    }

    .project-info p {
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .project-category {
      font-size: 0.72rem;
      margin-bottom: 0.5rem;
    }

    .tag {
      font-size: 0.72rem;
      padding: 0.32rem 0.65rem;
    }

    .small {
      padding: 0.42rem 0.85rem;
      font-size: 0.74rem;
    }

    .project-overlay {
      padding: 1.25rem;
    }
  }
</style>
