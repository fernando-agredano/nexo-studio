---
const mapsUrl =
  'https://www.google.com/maps/search/?api=1&query=Guadalajara%2C+Jalisco%2C+México';
const email = 'hola@nexoestudio.com';
const social = {
  instagram: 'https://www.instagram.com/',
  facebook: 'https://www.facebook.com/',
};
---

<section id="contacto" class="section">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <div class="contact-info__intro">
          <h2 class="section-title section-title--contact">
            Tu <span class="text-gradient">próximo hito</span> empieza aquí
          </h2>
          <p class="contact-lead">
            Escríbenos y te respondemos con una propuesta clara en 24–48 h hábiles.
          </p>
        </div>

        <ul class="contact-links">
          <li>
            <a class="contact-row" href={mapsUrl} target="_blank" rel="noopener noreferrer">
              <span class="contact-row__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <span class="contact-row__text">Guadalajara, Jalisco, México</span>
            </a>
          </li>
          <li>
            <a class="contact-row" href={`mailto:${email}`}>
              <span class="contact-row__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </span>
              <span class="contact-row__text">{email}</span>
            </a>
          </li>
          <li>
            <a
              class="contact-row"
              href={social.instagram}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="contact-row__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </span>
              <span class="contact-row__text">Instagram</span>
            </a>
          </li>
          <li>
            <a
              class="contact-row"
              href={social.facebook}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="contact-row__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </span>
              <span class="contact-row__text">Facebook</span>
            </a>
          </li>
        </ul>
      </div>

      <div class="contact-form-container glass">
        <h3 class="form-heading">Enviar mensaje</h3>
        <p class="form-hint">Respuesta típica en 24–48 h hábiles.</p>
        <form class="contact-form">
          <div class="form-group">
            <label for="name">Nombre Completo</label>
            <input type="text" id="name" name="name" placeholder="Tu nombre..." required />
          </div>

          <div class="form-group">
            <label for="email">E-mail Corporativo</label>
            <input type="email" id="email" name="email" placeholder="email@empresa.com" required />
          </div>

          <div class="form-group">
            <label for="project">Tipo de Proyecto</label>
            <select id="project" name="project">
              <option value="video">Producción Visual</option>
              <option value="web">Desarrollo Web</option>
              <option value="branding">Branding & Identidad</option>
              <option value="other">Otros</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Mensaje</label>
            <textarea id="message" name="message" rows="4" placeholder="Cuéntanos un poco sobre tu visión..."></textarea>
          </div>

          <button type="submit" class="btn btn-primary">Enviar Mensaje</button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    align-items: start;
  }

  .contact-info__intro {
    margin-bottom: 2rem;
  }

  .section-title--contact {
    text-align: left;
    margin-bottom: 0.75rem;
  }

  .contact-lead {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.55;
    max-width: 28rem;
    margin: 0;
  }

  .contact-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    max-width: 28rem;
  }

  .contact-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.7rem 0.85rem;
    min-height: 0;
    text-decoration: none;
    color: inherit;
    border-radius: 14px;
    border: 1px solid transparent;
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      background 0.25s ease;
  }

  .contact-row:hover {
    transform: translateY(-2px);
    border-color: rgba(245, 158, 11, 0.55);
    background: linear-gradient(
      135deg,
      rgba(245, 158, 11, 0.06) 0%,
      rgba(16, 185, 129, 0.07) 100%
    );
    box-shadow:
      0 8px 28px rgba(0, 0, 0, 0.28),
      0 0 0 1px rgba(245, 158, 11, 0.2),
      0 0 22px rgba(16, 185, 129, 0.12);
  }

  .contact-row:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .contact-row__icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    color: var(--color-text-muted);
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      background 0.25s ease,
      color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .contact-row__icon svg {
    display: block;
    flex-shrink: 0;
  }

  .contact-row:hover .contact-row__icon {
    transform: scale(1.04);
    border-color: rgba(245, 158, 11, 0.65);
    background: rgba(16, 185, 129, 0.12);
    color: #34d399;
    box-shadow: 0 0 18px rgba(245, 158, 11, 0.22), 0 0 14px rgba(16, 185, 129, 0.18);
  }

  .contact-row__text {
    font-size: 0.98rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    word-break: break-word;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
  }

  .contact-row:hover .contact-row__text {
    color: #ecfdf5;
  }

  .contact-form-container {
    padding: clamp(1.5rem, 3vw, 2.25rem);
    border: 1px solid var(--color-border);
  }

  .form-heading {
    font-family: var(--font-display);
    font-size: 1.4rem;
    margin-bottom: 0.25rem;
  }

  .form-hint {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    margin-bottom: 1.15rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.05rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-group label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.6rem 0.9rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    color: var(--color-text);
    font-family: inherit;
    font-size: 1rem;
    transition: var(--transition-smooth);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    background: rgba(255, 255, 255, 0.06);
    box-shadow: 0 0 15px var(--color-primary-glow);
  }

  .contact-form button[type='submit'] {
    width: 100%;
    margin-top: 0.25rem;
    padding: 0.85rem 1.35rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  @media (max-width: 968px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 768px) {
    .contact-grid {
      gap: 2.25rem;
    }

    .section-title--contact {
      font-size: clamp(1.75rem, 6vw, 2.4rem);
    }

    .contact-lead {
      font-size: 0.98rem;
    }

    .form-heading {
      font-size: 1.2rem;
    }

    .contact-form-container {
      padding: 1.35rem 1.1rem;
    }

    .contact-form button[type='submit'] {
      font-size: 1rem;
      padding: 0.75rem 1.1rem;
    }
  }
</style>
